# Racine du dépôt Eaumalik
# Le runtime Node pré-installé (node-v20.17.0-linux-x64) est historiquement
# tracké depuis les commits initiaux — il est conservé tel quel.
# On ignore uniquement les futures archives redondantes à la racine.

# Archives runtime Node (déjà décompressées)
node.tar.gz
node.tar.xz

# Lockfiles racine parasites (le vrai vit dans eaumalik-saas/)
package-lock.json
!eaumalik-saas/package-lock.json
package.json

# Secrets / fichiers locaux non versionnés
.env
.env.local
.env.*.local
*.log
.DS_Store

# Tests Playwright (artefacts)
test-results/
playwright-report/
playwright/.cache/

# Mock data-store (contient potentiellement des secrets legacy —
# généré au runtime par src/data/localDb.ts). À NE PAS versionner.
eaumalik-saas/data-store/users.json
eaumalik-saas/data-store/users_archive.json
eaumalik-saas/data-store/password_resets.json
