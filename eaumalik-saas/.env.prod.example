# filepath: eaumalik-saas/.env.prod.example
# Copier vers .env.prod et remplir les vraies valeurs avant déploiement.
# ⚠️ NE JAMAIS COMMITER .env.prod

# --- App ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://eaumalik.com
NEXT_PUBLIC_USE_MOCKS=false

# --- Supabase (db-prod sur le serveur, exposé via db-dev.smartefp.com) ---
# Récupérer ces 3 valeurs côté serveur :
#   docker exec auth-prod env | grep -E 'JWT|ANON|SERVICE|GOTRUE'
NEXT_PUBLIC_SUPABASE_URL=https://db-dev.smartefp.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=<COLLER_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<COLLER_SERVICE_ROLE_KEY>

# --- Caddy côté serveur (déjà géré) ---
# Rien à ajouter ici : le bloc eaumalik.com { ... } est ajouté dans /etc/caddy/Caddyfile
