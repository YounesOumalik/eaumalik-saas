# filepath: eaumalik-saas/.env.prod.example
# Copier vers .env.prod (jamais commité — voir .gitignore) et remplir les vraies valeurs.
# Le fichier .env.prod doit être chmod 600 sur le VPS.
# Stockage long terme : dans un gestionnaire de secrets (Bitwarden / 1Password / Vault).
# Voir docs/OPERATIONS-SECURITY.md pour la procédure complète.

# --- App ---
NODE_ENV=production
# Port d'écoute du container (aligné sur ENV PORT=3100 du Dockerfile).
PORT=3100
NEXT_PUBLIC_APP_URL=https://eaumalik.com
NEXT_PUBLIC_USE_MOCKS=false

# --- Supabase (db-prod sur le serveur, exposé via db-dev.smartefp.com) ---
# Récupérer côté serveur :   docker exec auth-prod env | grep -E 'JWT|ANON|SERVICE|GOTRUE'
# ⚠️  Ces 2 clés DOIVENT avoir été générées APRÈS la dernière rotation (cf. F-09 SECURITY-AUDIT).
NEXT_PUBLIC_SUPABASE_URL=https://db-dev.smartefp.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=<COLLER_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=<COLLER_SERVICE_ROLE_KEY>

# --- CAPTCHA maison (anti-bot, signup/login/reset) — OBLIGATOIRE en prod ---
# Régénérer à chaque rotation :   openssl rand -hex 32
CAPTCHA_SECRET=<COLLER_CAPTCHA_SECRET>

# --- SMTP custom pour l'envoi des emails de recovery (OBLIGATOIRE en prod) ---
# Sans SMTP custom, Supabase est limité à ~3 emails/h (insuffisant pour le reset password).
# Configurer aussi côté dashboard Supabase : Auth → SMTP Settings → Enable Custom SMTP.
# Voir docs/OPERATIONS-SECURITY.md §"Configuration SMTP" pour les providers recommandés.
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASSWORD=<COLLER_RESEND_API_KEY>
# SMTP_FROM="EAUMALIK <no-reply@eaumalik.com>"
# Durée maximale du lien de récupération Supabase : 30 minutes.
# Cette variable est à définir dans l'environnement GoTrue (auth-prod), pas
# uniquement dans le container Next.js.
# GOTRUE_MAILER_OTP_EXP=1800

# --- Caddy côté serveur (déjà géré) ---
# Rien à ajouter ici : le bloc eaumalik.com { ... } est ajouté dans /etc/caddy/Caddyfile
