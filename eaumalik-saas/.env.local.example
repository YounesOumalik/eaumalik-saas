# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR-SERVICE-ROLE

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Toggle to enable mocks without Supabase (default: enabled in dev)
NEXT_PUBLIC_USE_MOCKS=true

# CAPTCHA maison (anti-bot, signup/login/reset) — optionnel en dev.
# Si vide : un secret déterministe dérivé du CWD est utilisé (uniquement NODE_ENV != production).
# EN PRODUCTION : OBLIGATOIRE. Générer avec : openssl rand -hex 32
# CAPTCHA_SECRET=
