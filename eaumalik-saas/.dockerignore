# filepath: eaumalik-saas/.dockerignore
node_modules
.next
out
.git
.github
.gitignore
.env
.env.local
.env*.local

# NOTE: .env.production DOIT être dans le contexte de
# build car le Dockerfile le COPY explicitement avant
# 'npm run build' pour que @next/env l'incline dans
# le bundle client. Sans ça, le bundle webpack a
# process.env.NEXT_PUBLIC_SUPABASE_URL = '' et la
# page /login bascule en mode dev en prod.
!.env.production
data-store/*.json
!data-store/.gitkeep
.DS_Store
*.log
npm-debug.log*
.vscode
.idea
*.md
!README.md
!Docs/**/*.md
next-env.d.ts
.venv
__pycache__
*.pyc
